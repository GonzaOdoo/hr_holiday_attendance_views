<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_hr_leave_liquidation_wizard_form"
            model="ir.ui.view">
        <field name="name">hr.leave.liquidation.wizard.form</field>
        <field name="model">hr.leave.liquidation.wizard</field>
        <field name="arch" type="xml">
            <form string="Liquidar vacaciones">

                <group>
                    <field name="report_id" invisible="1"/>

                    <field name="liquidation_date"/>

                </group>

                <footer>

                    <button
                        name="action_confirm"
                        string="Liquidar"
                        type="object"
                        class="btn-primary"/>

                    <button
                        string="Cancelar"
                        special="cancel"
                        class="btn-secondary"/>

                </footer>

            </form>
        </field>
    </record>

</odoo>