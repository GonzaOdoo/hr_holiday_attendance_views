<odoo>
    <record id="view_hr_leave_allocation_form_inherit_liquidation" model="ir.ui.view">
        <field name="name">hr.leave.allocation.form.inherit.liquidation</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form_manager"/>
        <field name="arch" type="xml">
            <xpath expr="//button" position="after">
                <button name="action_open_liquidation_wizard"
                        type="object"
                        string="Crear asiento de liquidacion"
                        class="btn-primary"
                        />
                <button name="action_recompute_liquidation_data"
                        type="object"
                        string="Calcular disponibles"
                        class="btn-secondary"
                        />
            </xpath>
        </field>
    </record>

    <record id="action_liquidate_selected_allocations" model="ir.actions.server">
        <field name="name">Liquidar seleccionados</field>
        <field name="model_id" ref="model_hr_leave_allocation_report"/>
        <field name="binding_model_id" ref="model_hr_leave_allocation_report"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_liquidate_selected_allocations()
        </field>
    </record>

    
        <record id="view_hr_leave_liquidation_tree" model="ir.ui.view">
            <field name="name">hr.leave.liquidation.tree</field>
            <field name="model">hr.leave.liquidation</field>
            <field name="arch" type="xml">
                <list>
                    <field name="employee_id" string="Empleado"/>
                    <field name="allocation_id" string="Asignación"/>
                    <field name="date_start" string="Inicio"/>
                    <field name="date_end" string="Fin"/>
                    <field name="days" string="Duración (días)"/>
                    <button string="Crear recibo de nómina" name="action_create_payslip" type="object" invisible="has_payslip"></button>
                    <field name="payslip_id" string="Recibo" widget="res_partner_many2one"></field>
                </list>
            </field>
        </record>
    
        <record id="view_hr_leave_liquidation_form" model="ir.ui.view">
            <field name="name">hr.leave.liquidation.form</field>
            <field name="model">hr.leave.liquidation</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button string="Crear recibo de nómina" name="action_create_payslip" type="object" invisible="has_payslip"></button>
                    </header>
                    <sheet>
                        <group>
                            <field name="employee_id" string="Empleado"/>
                            <field name="allocation_id" string="Asignación"/>
                            <field name="date_start" string="Inicio"/>
                            <field name="days" string="Duración (días)"/>
                            
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    
        <record id="action_hr_leave_liquidation" model="ir.actions.act_window">
            <field name="name">Liquidaciones de vacaciones</field>
            <field name="res_model">hr.leave.liquidation</field>
            <field name="view_mode">list,form</field>
        </record>
        
        <menuitem
            id="menu_hr_leave_liquidation"
            name="Liquidaciones"
            parent="hr_holidays.menu_hr_holidays_management"
            action="action_hr_leave_liquidation"
            sequence="100"/>
                
</odoo>